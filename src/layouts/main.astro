---
import NavBar from "@/components/NavBar.astro";
import "@/styles/global.css";
const {
  title = "Kipkirui Koech — CS Student and Software Developer",
  description = "CS Student and Software Developer specializing in React, TypeScript, and Tailwind CSS. Passionate about building clean, responsive, and interactive web experiences. Experienced in creating modern UIs, responsive landing pages, and dynamic web applications with a focus on performance, usability, and clean component structure.",
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
	<link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
	<meta name="description" content={description} />
	<meta name="author" content="Kipkirui Koech" />
	<meta
      name="keywords"
      content="Kipkirui Koech,Software Developer,React,Next.js,TypeScript,Python,Web development,developer tools."
    />
	<meta name="robots" content="index, follow" />
	<meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Kipkirui's Portfolio" />
	<meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <script
      defer
      src="https://metrics.kipkirui.dev/script.js"
      data-website-id="527ee60d-1251-4a85-bd2d-27febe67bf1b"></script>
    <script defer>
      const updateProgress = () => {
        const scrollTop =
          window.pageYOffset || document.documentElement.scrollTop;
        const scrollHeight =
          document.documentElement.scrollHeight - window.innerHeight;
        const progress = (scrollTop / scrollHeight) * 100;
        const progressBar = document.getElementById("reading-progress");
        if (progressBar) {
          progressBar.style.width = `${progress}%`;
        }
      };

      window.addEventListener("scroll", updateProgress, { passive: true });
      const getThemePreference = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };

      const isDark = getThemePreference() === "dark";
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");

      if (typeof localStorage !== "undefined") {
        localStorage.setItem("theme", isDark ? "dark" : "light");
      }
    </script>
  </head>
  <body>
    <div
      class="fixed top-0 left-0 h-0.5 bg-primary transition-all duration-100 ease-out z-50 w-0"
      id="reading-progress"
    >
    </div>
    <NavBar />
    <slot />
    <footer
      class="mt-8 md:mt-12 py-4 md:py-6 border-t border-t-ring animate-fade-in"
    >
      <div
        class="max-w-2xl mx-auto px-6 flex justify-between font-normal text-sm text-muted-foreground"
      >
        <span class="">&copy; {new Date().getFullYear()} Kipkirui Koech</span>
        <span class="">Built with Astro</span>
      </div>
    </footer>
  </body>
</html>
