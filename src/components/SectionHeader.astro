---
interface Props {
  title: string;
  number: string;
}

const { title, number } = Astro.props;
---

<div class="flex items-baseline gap-3 pb-5 border-b border-border mb-8 max-md:px-0 max-md:pt-0 max-md:pb-4 max-md:mb-6">
  <span class="section-number text-xs font-mono -tracking-tighter whitespace-nowrap shrink-0">{number}</span>
  <h2 class="section-title font-semibold lowercase m-0">{title}</h2>
</div>

<style>
  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    letter-spacing: 0.03em;
    line-height: 1.2;
  }

  .section-number {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--tertiary-text);
  }
</style>
