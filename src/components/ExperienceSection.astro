---
interface Experience {
  data: {
    title: string;
    company: string;
    period: string;
    href?: string;
    tech?: string[];
    description: string;
  }
}

const { experiences } = Astro.props as { experiences: Experience[] };
---

<div class="flex flex-col gap-12">
  {
    experiences.map((experience) => (
      <article class="grid grid-cols-[140px_1fr] gap-8">
        <div class="text-sm text-muted-foreground">
          {experience.data.period}
        </div>

        <div>
          <h3 class="text-lg font-semibold">
            {experience.data.title} — {experience.data.company}
          </h3>
          <div class="mt-2 font-light prose prose-invert max-w-none">
            <p>{experience.data.description}</p>
          </div>

          <div class="mt-2 flex flex-wrap gap-2">
            {experience.data.tech?.map((item) => (
              <span class="rounded-full border border-border px-3 py-1 text-sm">
                {item}
              </span>
            ))}
          </div>
        </div>
      </article>
    ))
  }
</div>
